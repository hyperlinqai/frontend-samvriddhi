<h2 class="mb-4">Attendance Monitoring</h2>
<div class="card shadow">
    <div class="card-body">
        <form class="row g-3 mb-4">
            <div class="col-auto">
                <input type="date" class="form-control" name="date">
            </div>
            <div class="col-auto">
                <button type="submit" class="btn btn-primary">Filter</button>
            </div>
        </form>
        <div class="table-responsive">
            <table class="table table-striped table-hover">
                <thead>
                    <tr>
                        <th>Employee</th>
                        <th>Date</th>
                        <th>Status</th>
                        <th>Check In</th>
                        <th>Check Out</th>
                    </tr>
                </thead>
                <tbody>
                    <% logs.forEach(log=> { %>
                        <tr>
                            <td>
                                <%= log.employee %>
                            </td>
                            <td>
                                <%= log.date %>
                            </td>
                            <td>
                                <span class="badge <%= log.status === 'Present' ? 'bg-success' : 'bg-danger' %>">
                                    <%= log.status %>
                                </span>
                            </td>
                            <td>
                                <%= log.checkIn %>
                            </td>
                            <td>
                                <%= log.checkOut %>
                            </td>
                        </tr>
                        <% }) %>
                </tbody>
            </table>
        </div>
    </div>
</div>