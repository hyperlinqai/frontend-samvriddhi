<div class="error-page-container">
    <div class="error-page-card">
        <div class="error-page-illustration">
            <div class="error-code">403</div>
            <div class="error-icon-wrap error-icon-forbidden">
                <i class="bi bi-shield-x"></i>
            </div>
        </div>
        <h2 class="error-page-title">Access Denied</h2>
        <p class="error-page-message">
            You don't have permission to access this page. Please contact your administrator if you believe this is an
            error.
        </p>
        <div class="error-page-actions">
            <a href="/dashboard" class="btn-theme"
                style="border-radius: var(--radius-sm); padding: 12px 28px; text-decoration: none;">
                <i class="bi bi-house me-1"></i> Go to Dashboard
            </a>
            <a href="javascript:history.back()" class="modal-btn-cancel"
                style="text-decoration: none; padding: 12px 28px;">
                <i class="bi bi-arrow-left me-1"></i> Go Back
            </a>
        </div>
    </div>
</div>