<div class="login-container">
    <div class="login-card" style="animation: fadeInUp 0.5s ease forwards;">
        <!-- Brand -->
        <div class="text-center mb-4">
            <div class="d-inline-flex align-items-center justify-content-center mb-3"
                style="width: 52px; height: 52px; background: linear-gradient(135deg, var(--accent), #BFB33E); border-radius: 12px;">
                <span style="font-size: 22px; font-weight: 700; color: var(--text-primary);">S</span>
            </div>
            <h2 style="font-weight: 700; letter-spacing: -0.5px;">Forgot Password</h2>
            <p style="color: var(--text-muted); font-size: 0.9rem;">Enter your email and we'll send you a reset link</p>
        </div>

        <% if (typeof error !=='undefined' && error) { %>
            <div class="alert alert-danger d-flex align-items-center" role="alert"
                style="border-radius: var(--radius-sm); font-size: 0.85rem; border: none; background: var(--danger-soft); color: var(--danger);">
                <i class="bi bi-exclamation-circle me-2"></i>
                <%= error %>
            </div>
            <% } %>

                <% if (typeof success !=='undefined' && success) { %>
                    <div class="alert d-flex align-items-center" role="alert"
                        style="border-radius: var(--radius-sm); font-size: 0.85rem; border: none; background: var(--success-soft); color: var(--success);">
                        <i class="bi bi-check-circle me-2"></i>
                        <%= success %>
                    </div>
                    <% } %>

                        <form action="/forgot-password" method="POST">
                            <div class="mb-4">
                                <label for="email" class="form-label"
                                    style="font-weight: 500; font-size: 0.85rem; color: var(--text-secondary);">Email
                                    address</label>
                                <input type="email" class="form-control" id="email" name="email" required
                                    placeholder="Enter your registered email"
                                    style="padding: 12px 16px; border-radius: var(--radius-sm);">
                            </div>
                            <div class="d-grid">
                                <button type="submit" class="btn-theme"
                                    style="padding: 13px; font-size: 0.95rem; border-radius: var(--radius-sm);">
                                    Send Reset Link <i class="bi bi-send ms-1"></i>
                                </button>
                            </div>
                        </form>

                        <div class="mt-4 text-center"
                            style="border-top: 1px solid var(--border-light); padding-top: 16px;">
                            <a href="/login"
                                style="color: var(--text-secondary); font-size: 0.85rem; text-decoration: none;">
                                <i class="bi bi-arrow-left me-1"></i> Back to Sign In
                            </a>
                        </div>
    </div>
</div>