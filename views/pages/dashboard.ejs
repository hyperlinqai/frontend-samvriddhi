<!-- Dashboard Page -->
<h1 class="page-heading animate-in">Dashboard</h1>

<!-- Stat Cards -->
<div class="stats-grid animate-in-delay-1">
    <div class="stat-card">
        <div class="stat-card-icon icon-primary">
            <i class="bi bi-people-fill"></i>
        </div>
        <div class="stat-card-content">
            <span class="stat-card-label">Total Staff</span>
            <span class="stat-card-value">
                <%= stats.totalEmployees %>
            </span>
        </div>
    </div>

    <div class="stat-card">
        <div class="stat-card-icon icon-success">
            <i class="bi bi-check-circle-fill"></i>
        </div>
        <div class="stat-card-content">
            <span class="stat-card-label">Present Today</span>
            <span class="stat-card-value">
                <%= stats.presentToday %>
            </span>
        </div>
    </div>

    <div class="stat-card">
        <div class="stat-card-icon icon-warning">
            <i class="bi bi-clock-fill"></i>
        </div>
        <div class="stat-card-content">
            <span class="stat-card-label">Pending Expenses</span>
            <span class="stat-card-value">
                <%= stats.pendingExpenses %>
            </span>
        </div>
    </div>
</div>

<!-- Two Column: Status Bar + Summary -->
<div class="dashboard-two-col animate-in-delay-2">
    <!-- Left: Employee Status Distribution -->
    <div class="panel-card">
        <div class="panel-card-title">
            Staff Status Overview
            <span class="title-badge">Today</span>
        </div>

        <div class="status-items">
            <div class="status-item">
                <span class="status-item-value">
                    <%= stats.presentToday %>
                </span>
                <span class="status-item-label">Present</span>
            </div>
            <div class="status-item">
                <span class="status-item-value">
                    <%= stats.absentToday %>
                </span>
                <span class="status-item-label">Absent</span>
            </div>
            <div class="status-item">
                <span class="status-item-value">
                    <%= stats.totalEmployees %>
                </span>
                <span class="status-item-label">Total Staff</span>
            </div>
        </div>

        <div class="status-bar-container">
            <div class="status-bar">
                <% const total=stats.totalEmployees || 1; const presentPct=Math.round((stats.presentToday / total) *
                    100); const absentPct=Math.round((stats.absentToday / total) * 100); const otherPct=100 - presentPct
                    - absentPct; %>
                    <div class="status-bar-segment seg-accent" style="width: <%= presentPct %>%"></div>
                    <div class="status-bar-segment seg-dark" style="width: <%= absentPct %>%"></div>
                    <div class="status-bar-segment seg-gray" style="width: <%= otherPct > 0 ? otherPct : 0 %>%"></div>
            </div>
            <div class="status-bar-legend">
                <div class="legend-item">
                    <div class="legend-dot" style="background: var(--accent);"></div>
                    Present (<%= presentPct %>%)
                </div>
                <div class="legend-item">
                    <div class="legend-dot" style="background: var(--text-primary);"></div>
                    Absent (<%= absentPct %>%)
                </div>
                <% if (otherPct> 0) { %>
                    <div class="legend-item">
                        <div class="legend-dot" style="background: var(--text-muted);"></div>
                        Other (<%= otherPct %>%)
                    </div>
                    <% } %>
            </div>
        </div>
    </div>

    <!-- Right: Summary Panel -->
    <div class="panel-card">
        <div class="panel-card-title">
            Quick Summary
        </div>

        <div class="summary-list">
            <div class="summary-row">
                <span class="summary-row-label">Total Employees</span>
                <span class="summary-row-value">
                    <%= stats.totalEmployees %>
                </span>
            </div>
            <div class="summary-row">
                <span class="summary-row-label">Present Today</span>
                <span class="summary-row-value" style="color: var(--success);">
                    <%= stats.presentToday %>
                </span>
            </div>
            <div class="summary-row">
                <span class="summary-row-label">Absent Today</span>
                <span class="summary-row-value" style="color: var(--danger);">
                    <%= stats.absentToday %>
                </span>
            </div>
            <div class="summary-row">
                <span class="summary-row-label">Pending Expenses</span>
                <span class="summary-row-value">
                    <%= stats.pendingExpenses %>
                </span>
            </div>
        </div>

        <!-- Mini presence bar -->
        <div class="summary-mini-bar" style="margin-top: 20px;">
            <div class="status-bar-segment seg-dark" style="width: <%= presentPct %>%"></div>
            <div class="status-bar-segment seg-accent" style="width: <%= 100 - presentPct %>%"></div>
        </div>
        <div class="d-flex justify-content-between mt-2" style="font-size: 0.72rem; color: var(--text-muted);">
            <span><i class="bi bi-circle-fill" style="font-size: 6px; color: var(--text-primary);"></i> Present</span>
            <span><i class="bi bi-circle-fill" style="font-size: 6px; color: var(--accent);"></i> Remaining</span>
        </div>
    </div>
</div>

<!-- Charts Section (Attendance Trends) -->
<div class="chart-card animate-in-delay-3">
    <div class="chart-header">
        <span class="chart-title">Attendance Trends</span>
        <div class="chart-controls">
            <button class="chart-control-btn active" data-range="week">This Week</button>
            <button class="chart-control-btn" data-range="month">This Month</button>
        </div>
    </div>

    <div class="bar-chart-container" style="position: relative; padding-left: 36px;">
        <div class="bar-chart" id="attendanceChart">
            <!-- Bars are generated dynamically by JS -->
        </div>
        <div class="d-flex justify-content-between px-1 mt-2">
            <span class="bar-label">Mon</span>
            <span class="bar-label">Tue</span>
            <span class="bar-label">Wed</span>
            <span class="bar-label">Thu</span>
            <span class="bar-label">Fri</span>
            <span class="bar-label">Sat</span>
            <span class="bar-label">Sun</span>
        </div>
    </div>
</div>

<!-- Attendance Trend Data for Chart -->
<script>
    window.__dashboardStats = {
        totalEmployees: <%= stats.totalEmployees %>,
        presentToday: <%= stats.presentToday %>,
        absentToday: <%= stats.absentToday %>,
        pendingExpenses: <%= stats.pendingExpenses %>
    };
</script>