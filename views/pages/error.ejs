<div class="text-center mt-5">
    <h1 class="display-1 text-danger">
        <%= error.status || 500 %>
    </h1>
    <h2>
        <%= message %>
    </h2>
    <% if (error.stack && process.env.NODE_ENV !=='production' ) { %>
        <pre class="text-start mt-4 p-3 bg-light border rounded"><code><%= error.stack %></code></pre>
        <% } %>
            <a href="/dashboard" class="btn btn-primary mt-3">Return to Dashboard</a>
</div>