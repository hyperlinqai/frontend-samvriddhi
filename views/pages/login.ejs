<div class="login-container">
    <div class="login-card" style="animation: fadeInUp 0.5s ease forwards;">
        <!-- Brand -->
        <div class="text-center mb-4">
            <div class="d-inline-flex align-items-center justify-content-center mb-3"
                style="width: 52px; height: 52px; background: linear-gradient(135deg, var(--accent), #BFB33E); border-radius: 12px;">
                <span style="font-size: 22px; font-weight: 700; color: var(--text-primary);">S</span>
            </div>
            <h2 style="font-weight: 700; letter-spacing: -0.5px;">Samvriddhi</h2>
            <p style="color: var(--text-muted); font-size: 0.9rem;">Sign in to your dashboard</p>
        </div>

        <% if (typeof error !=='undefined' && error) { %>
            <div class="alert alert-danger d-flex align-items-center" role="alert"
                style="border-radius: var(--radius-sm); font-size: 0.85rem; border: none; background: var(--danger-soft); color: var(--danger);">
                <i class="bi bi-exclamation-circle me-2"></i>
                <%= error %>
            </div>
            <% } %>

                <form action="/login" method="POST">
                    <div class="mb-3">
                        <label for="email" class="form-label"
                            style="font-weight: 500; font-size: 0.85rem; color: var(--text-secondary);">Email
                            address</label>
                        <input type="email" class="form-control" id="email" name="email" required
                            placeholder="shoaib.khan@hyperlinq.in" value="shoaib.khan@hyperlinq.in"
                            style="padding: 12px 16px; border-radius: var(--radius-sm);">
                    </div>
                    <div class="mb-4">
                        <label for="password" class="form-label"
                            style="font-weight: 500; font-size: 0.85rem; color: var(--text-secondary);">Password</label>
                        <input type="password" class="form-control" id="password" name="password" required
                            placeholder="Hyperlinq3b$" value="Hyperlinq3b$"
                            style="padding: 12px 16px; border-radius: var(--radius-sm);">
                    </div>
                    <div class="d-grid">
                        <button type="submit" class="btn-theme"
                            style="padding: 13px; font-size: 0.95rem; border-radius: var(--radius-sm);">
                            Sign In <i class="bi bi-arrow-right ms-1"></i>
                        </button>
                    </div>
                </form>

                <div class="mt-3 text-center">
                    <a href="/forgot-password"
                        style="color: var(--text-muted); font-size: 0.85rem; text-decoration: none; transition: color 0.15s ease;">
                        Forgot your password?
                    </a>
                </div>

                <div class="mt-3 text-center" style="border-top: 1px solid var(--border-light); padding-top: 16px;">
                    <small style="color: var(--text-muted); font-size: 0.78rem;">
                        Admin credentials:<br>
                        <span style="color: var(--text-secondary);">superadmin@samvirddhi.com / Admin@123456</span>
                    </small>
                </div>
    </div>
</div>