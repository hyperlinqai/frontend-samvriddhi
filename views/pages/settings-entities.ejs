<!-- Toast Notification -->
<div id="toast-container" class="position-fixed top-0 end-0 p-3" style="z-index: 1080;">
    <% if (typeof success !=='undefined' && success) { %>
        <div class="toast align-items-center text-bg-success border-0 show" role="alert">
            <div class="d-flex">
                <div class="toast-body"><i class="bi bi-check-circle me-2"></i>
                    <%= success %>
                </div>
                <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast"></button>
            </div>
        </div>
        <% } %>
            <% if (typeof error !=='undefined' && error) { %>
                <div class="toast align-items-center text-bg-danger border-0 show" role="alert">
                    <div class="d-flex">
                        <div class="toast-body"><i class="bi bi-exclamation-triangle me-2"></i>
                            <%= error %>
                        </div>
                        <button type="button" class="btn-close btn-close-white me-2 m-auto"
                            data-bs-dismiss="toast"></button>
                    </div>
                </div>
                <% } %>
</div>

<!-- Settings Sub-Navigation -->
<div class="settings-subnav">
    <a href="/settings" class="settings-subnav-item">
        <i class="bi bi-people"></i> Users
    </a>
    <a href="/settings/entities" class="settings-subnav-item active">
        <i class="bi bi-building"></i> Entities
    </a>
    <a href="/settings/roles" class="settings-subnav-item">
        <i class="bi bi-shield-lock"></i> Roles & Permissions
    </a>
</div>

<!-- Page Header -->
<div class="settings-page-header">
    <div>
        <h2 class="settings-title">Entity Management</h2>
        <p class="settings-subtitle">Create, edit, and manage entities across the system</p>
    </div>
    <button class="btn-add-user" data-bs-toggle="modal" data-bs-target="#createEntityModal">
        <i class="bi bi-plus-lg"></i>
        <span>Add Entity</span>
    </button>
</div>

<!-- Filter Bar -->
<div class="settings-filters">
    <form action="/settings/entities" method="GET" class="settings-filter-form" id="filterForm">
        <div class="filter-search">
            <i class="bi bi-search"></i>
            <input type="text" name="search" placeholder="Search by name or code..." value="<%= filters.search %>"
                id="searchInput">
        </div>
        <div class="filter-role">
            <select name="status" id="statusFilter" onchange="document.getElementById('filterForm').submit()">
                <option value="">All Status</option>
                <option value="true" <%=filters.status==='true' ? 'selected' : '' %>>Active</option>
                <option value="false" <%=filters.status==='false' ? 'selected' : '' %>>Inactive</option>
            </select>
        </div>
        <button type="submit" class="filter-btn">
            <i class="bi bi-funnel"></i> Filter
        </button>
        <% if (filters.search || filters.status) { %>
            <a href="/settings/entities" class="filter-clear-btn">
                <i class="bi bi-x-lg"></i> Clear
            </a>
            <% } %>
    </form>
</div>

<!-- Entity Table -->
<div class="settings-card">
    <div class="settings-card-header">
        <span class="settings-card-title">
            <i class="bi bi-building me-2"></i>All Entities
        </span>
        <span class="settings-card-badge">
            <%= meta.total %> total
        </span>
    </div>

    <% if (entities.length===0) { %>
        <div class="text-center py-5">
            <div class="empty-state">
                <i class="bi bi-building" style="font-size: 2.5rem; color: var(--text-muted);"></i>
                <h4 class="mt-3 mb-1" style="color: var(--text-muted);">No entities found</h4>
                <small style="color: var(--text-muted);">Create your first entity to get started or clear
                    filters</small>
            </div>
        </div>
        <% } else { %>
            <div class="table-responsive">
                <table class="settings-table" id="entitiesTable">
                    <thead>
                        <tr>
                            <th>Entity</th>
                            <th>Code</th>
                            <th>Status</th>
                            <th>Created</th>
                            <th class="text-end">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% entities.forEach(entity=> { %>
                            <tr>
                                <td>
                                    <div class="user-cell">
                                        <div class="user-avatar-sm">
                                            <%= entity.name ? entity.name.charAt(0).toUpperCase() : 'E' %>
                                        </div>
                                        <div>
                                            <div class="user-name">
                                                <%= entity.name %>
                                            </div>
                                            <div class="user-id">ID: <%= entity.id ? entity.id.substring(0, 8) : 'N/A'
                                                    %>...</div>
                                        </div>
                                    </div>
                                </td>
                                <td>
                                    <span class="role-badge" style="background: var(--info-soft); color: var(--info);">
                                        <%= entity.code %>
                                    </span>
                                </td>
                                <td>
                                    <span
                                        class="status-badge status-<%= entity.status !== false ? 'active' : 'inactive' %>">
                                        <span class="status-dot"></span>
                                        <%= entity.status !==false ? 'Active' : 'Inactive' %>
                                    </span>
                                </td>
                                <td>
                                    <%= entity.createdAt ? new Date(entity.createdAt).toLocaleDateString('en-IN', {
                                        day: '2-digit' , month: 'short' , year: 'numeric' }) : 'N/A' %>
                                </td>
                                <td class="text-end">
                                    <div class="action-btns">
                                        <button class="action-btn action-edit" title="Edit Entity"
                                            onclick="openEditEntityModal('<%= entity.id %>', '<%= entity.name %>', '<%= entity.code %>', '<%= entity.status %>')">
                                            <i class="bi bi-pencil"></i>
                                        </button>
                                        <% if (entity.status !==false) { %>
                                            <button class="action-btn action-deactivate" title="Deactivate Entity"
                                                onclick="openDeactivateEntityModal('<%= entity.id %>', '<%= entity.name %>')">
                                                <i class="bi bi-x-circle"></i>
                                            </button>
                                            <% } else { %>
                                                <form method="POST"
                                                    action="/settings/entities/<%= entity.id %>/reactivate"
                                                    style="display:inline;">
                                                    <button type="submit" class="action-btn action-edit"
                                                        title="Reactivate Entity"
                                                        onclick="return confirm('Are you sure you want to reactivate <%= entity.name %>?')">
                                                        <i class="bi bi-play-circle"></i>
                                                    </button>
                                                </form>
                                                <% } %>
                                    </div>
                                </td>
                            </tr>
                            <% }) %>
                    </tbody>
                </table>
            </div>

            <!-- Pagination -->
            <% if (meta.totalPages> 1) { %>
                <div class="settings-pagination">
                    <span class="pagination-info">
                        Page <%= meta.page %> of <%= meta.totalPages %> · Showing <%= entities.length %> of <%=
                                        meta.total %>
                    </span>
                    <div class="pagination-btns">
                        <% if (meta.page> 1) { %>
                            <a href="/settings/entities?page=<%= meta.page - 1 %>&search=<%= filters.search %>&status=<%= filters.status %>"
                                class="pagination-btn">
                                <i class="bi bi-chevron-left"></i> Prev
                            </a>
                            <% } %>
                                <% if (meta.page < meta.totalPages) { %>
                                    <a href="/settings/entities?page=<%= meta.page + 1 %>&search=<%= filters.search %>&status=<%= filters.status %>"
                                        class="pagination-btn">
                                        Next <i class="bi bi-chevron-right"></i>
                                    </a>
                                    <% } %>
                    </div>
                </div>
                <% } %>
                    <% } %>
</div>

<!-- Create Entity Modal -->
<div class="modal fade" id="createEntityModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content settings-modal">
            <div class="modal-header settings-modal-header">
                <div>
                    <h5 class="modal-title settings-modal-title">Add New Entity</h5>
                    <p class="settings-modal-subtitle">Create a new entity in the system</p>
                </div>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <form action="/settings/entities" method="POST">
                <div class="modal-body settings-modal-body">
                    <div class="form-group">
                        <label for="entityName">Entity Name <span class="required">*</span></label>
                        <input type="text" id="entityName" name="name" placeholder="e.g. Samvriddhi Financial Services"
                            required>
                    </div>
                    <div class="form-group">
                        <label for="entityCode">Entity Code <span class="required">*</span></label>
                        <input type="text" id="entityCode" name="code" placeholder="e.g. SFS" required
                            style="text-transform: uppercase;">
                    </div>
                </div>
                <div class="modal-footer settings-modal-footer">
                    <button type="button" class="modal-btn-cancel" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="modal-btn-submit">
                        <i class="bi bi-plus-lg me-1"></i> Create Entity
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Edit Entity Modal -->
<div class="modal fade" id="editEntityModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content settings-modal">
            <div class="modal-header settings-modal-header">
                <div>
                    <h5 class="modal-title settings-modal-title">Edit Entity</h5>
                    <p class="settings-modal-subtitle">Update entity details</p>
                </div>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <form id="editEntityForm" method="POST" hx-boost="false">
                <div class="modal-body settings-modal-body">
                    <div class="form-group">
                        <label for="editEntityName">Entity Name <span class="required">*</span></label>
                        <input type="text" id="editEntityName" name="name" required>
                    </div>
                    <div class="form-group">
                        <label for="editEntityCode">Entity Code <span class="required">*</span></label>
                        <input type="text" id="editEntityCode" name="code" required style="text-transform: uppercase;">
                    </div>
                    <div class="form-group">
                        <label for="editEntityStatus">Status</label>
                        <select id="editEntityStatus" name="status">
                            <option value="true">Active</option>
                            <option value="false">Inactive</option>
                        </select>
                    </div>
                </div>
                <div class="modal-footer settings-modal-footer">
                    <button type="button" class="modal-btn-cancel" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="modal-btn-submit">
                        <i class="bi bi-check-lg me-1"></i> Save Changes
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Deactivate Entity Modal -->
<div class="modal fade" id="deactivateEntityModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-sm">
        <div class="modal-content settings-modal">
            <div class="modal-header settings-modal-header">
                <div>
                    <h5 class="modal-title settings-modal-title" style="color: var(--danger);">Deactivate Entity</h5>
                    <p class="settings-modal-subtitle">This action will disable the entity</p>
                </div>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <form id="deactivateEntityForm" method="POST" hx-boost="false">
                <div class="modal-body settings-modal-body">
                    <div class="text-center py-2">
                        <div class="mb-3" style="font-size: 2.5rem; color: var(--danger);"><i
                                class="bi bi-exclamation-triangle"></i></div>
                        <p>Are you sure you want to deactivate <strong id="deactivateEntityName"></strong>?</p>
                        <small class="text-muted">The entity will be marked as inactive.</small>
                    </div>
                </div>
                <div class="modal-footer settings-modal-footer">
                    <button type="button" class="modal-btn-cancel" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="modal-btn-submit" style="background: var(--danger);">
                        <i class="bi bi-x-circle me-1"></i> Deactivate
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>



<script>
    function openEditEntityModal(id, name, code, status) {
        document.getElementById('editEntityForm').setAttribute('action', '/settings/entities/' + id + '/edit');
        document.getElementById('editEntityName').value = name;
        document.getElementById('editEntityCode').value = code;
        document.getElementById('editEntityStatus').value = status;
        new bootstrap.Modal(document.getElementById('editEntityModal')).show();
    }

    function openDeactivateEntityModal(id, name) {
        document.getElementById('deactivateEntityForm').setAttribute('action', '/settings/entities/' + id + '/deactivate');
        document.getElementById('deactivateEntityName').textContent = name;
        new bootstrap.Modal(document.getElementById('deactivateEntityModal')).show();
    }



    // Auto-dismiss toasts
    document.querySelectorAll('.toast.show').forEach(toast => {
        setTimeout(() => {
            toast.classList.remove('show');
            toast.style.opacity = '0';
            setTimeout(() => toast.remove(), 300);
        }, 4000);
    });
</script>